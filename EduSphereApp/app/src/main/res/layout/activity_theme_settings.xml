<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Appearance"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="32dp"/>

    <RadioGroup
        android:id="@+id/themeRg"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <RadioButton android:id="@+id/lightRb" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Light Mode"/>
        <RadioButton android:id="@+id/darkRb" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Dark Mode"/>
        <RadioButton android:id="@+id/systemRb" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="System Default"/>
    </RadioGroup>

</LinearLayout>