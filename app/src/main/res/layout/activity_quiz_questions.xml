<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#12104A">

    <View
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="140dp"
        android:background="@drawable/bg_futuristic_gradient"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageButton
        android:id="@+id/quizBackBtn"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@android:drawable/ic_media_previous"
        app:tint="@color/white" />

    <TextView
        android:id="@+id/quizTopicTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:text="Quiz"
        android:textColor="@color/white"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@+id/quizBackBtn"
        app:layout_constraintEnd_toStartOf="@+id/scoreTv"
        app:layout_constraintStart_toEndOf="@+id/quizBackBtn"
        app:layout_constraintTop_toTopOf="@+id/quizBackBtn" />

    <TextView
        android:id="@+id/scoreTv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="16dp"
        android:text="Score: 0"
        android:textColor="@color/primary_cyan"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@+id/quizBackBtn"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/quizBackBtn" />

    <ProgressBar
        android:id="@+id/quizProgress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="8dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="24dp"
        android:progressTint="@color/primary_cyan"
        android:progressBackgroundTint="#2A2750"
        app:layout_constraintTop_toBottomOf="@+id/quizBackBtn" />

    <TextView
        android:id="@+id/questionNumTv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Question 1 of 10"
        android:textColor="#888888"
        android:textSize="12sp"
        app:layout_constraintEnd_toEndOf="@+id/quizProgress"
        app:layout_constraintTop_toBottomOf="@+id/quizProgress" />

    <TextView
        android:id="@+id/timerTv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="⏱ 30s"
        android:textColor="@color/primary_purple"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="@+id/quizProgress"
        app:layout_constraintTop_toTopOf="@+id/questionNumTv" />

    <androidx.cardview.widget.CardView
        android:id="@+id/questionCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="24dp"
        app:cardBackgroundColor="#1E1B3A"
        app:cardCornerRadius="24dp"
        app:cardElevation="8dp"
        app:layout_constraintTop_toBottomOf="@+id/questionNumTv">

        <TextView
            android:id="@+id/questionTv"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="24dp"
            android:text="How many planets are in our solar system?"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold" />
    </androidx.cardview.widget.CardView>

    <LinearLayout
        android:id="@+id/optionsLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="24dp"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@+id/questionCard">

        <Button
            android:id="@+id/optionA"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginBottom="12dp"
            android:text="Option A"
            android:textAlignment="viewStart"
            android:textColor="@color/white"
            app:backgroundTint="#1E1B3A" />

        <Button
            android:id="@+id/optionB"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginBottom="12dp"
            android:text="Option B"
            android:textAlignment="viewStart"
            android:textColor="@color/white"
            app:backgroundTint="#1E1B3A" />

        <Button
            android:id="@+id/optionC"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginBottom="12dp"
            android:text="Option C"
            android:textAlignment="viewStart"
            android:textColor="@color/white"
            app:backgroundTint="#1E1B3A" />

        <Button
            android:id="@+id/optionD"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginBottom="12dp"
            android:text="Option D"
            android:textAlignment="viewStart"
            android:textColor="@color/white"
            app:backgroundTint="#1E1B3A" />

    </LinearLayout>

    <Button
        android:id="@+id/nextBtn"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="32dp"
        android:backgroundTint="@color/primary_purple"
        android:text="Next →"
        android:textColor="@color/white"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>